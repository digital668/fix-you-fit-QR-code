<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>FixYouFit Digital Card</title>

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">

<style>
* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

body {
  background: #F8FBFC;
  font-family: Arial, sans-serif;
  color: #1F2937;
  padding: 20px;
}

.fyf-wrapper {
  max-width: 540px;
  margin: 0 auto;
  background: #ffffff;
  border-radius: 30px;
  overflow: hidden;
  box-shadow: 0 18px 45px rgba(0,0,0,0.12);
}

.fyf-banner {
  height: 230px;
  background-image: linear-gradient(rgba(36,148,174,0.10), rgba(36,148,174,0.35)), url("data:image/jpeg;base64,");
  background-size: cover;
  background-position: center;
  position: relative;
}

.fyf-hero {
  background: linear-gradient(135deg, #2494AE, #1E8098);
  text-align: center;
  padding: 85px 25px 35px;
  color: #ffffff;
  position: relative;
}

.fyf-logo {
  width: 150px;
  height: 150px;
  background: #ffffff;
  border-radius: 50%;
  padding: 14px;
  border: 6px solid #F9C7A4;
  box-shadow: 0 12px 30px rgba(0,0,0,0.22);
  display: flex;
  align-items: center;
  justify-content: center;
  position: absolute;
  top: -75px;
  left: 50%;
  transform: translateX(-50%);
}

.fyf-logo img {
  width: 100%;
  height: 100%;
  object-fit: contain;
  border-radius: 50%;
}

.fyf-hero h1 {
  font-size: 38px;
  font-weight: 800;
  margin-bottom: 8px;
}

.fyf-hero p {
  font-size: 16px;
  opacity: 0.95;
}

.fyf-card {
  margin: 20px;
  background: #ffffff;
  padding: 24px;
  border-radius: 24px;
  box-shadow: 0 8px 24px rgba(0,0,0,0.08);
  border: 1px solid #eef2f3;
}

.fyf-card h2 {
  color: #2494AE;
  font-size: 23px;
  margin-bottom: 14px;
}

.fyf-card p {
  font-size: 15px;
  line-height: 1.75;
  color: #444444;
}

.fyf-location {
  border-left: 6px solid #F9C7A4;
}

.fyf-contact-row {
  display: flex;
  align-items: center;
  gap: 12px;
  margin: 14px 0;
  font-size: 15px;
  color: #333333;
}

.fyf-contact-row i {
  width: 42px;
  height: 42px;
  min-width: 42px;
  border-radius: 50%;
  background: #F9C7A4;
  color: #2494AE;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18px;
}

.fyf-buttons {
  margin: 20px;
  display: grid;
  gap: 14px;
}

.fyf-buttons a {
  text-decoration: none;
  background: #2494AE;
  color: #ffffff;
  padding: 15px 18px;
  border-radius: 50px;
  text-align: center;
  font-weight: 700;
  transition: 0.3s;
}

.fyf-buttons a i {
  margin-right: 8px;
}

.fyf-buttons a:hover {
  background: #F9C7A4;
  color: #1F2937;
  transform: translateY(-2px);
}

.fyf-footer {
  background: #2494AE;
  color: #ffffff;
  padding: 30px 20px;
  text-align: center;
}

.fyf-footer h3 {
  font-size: 22px;
  margin-bottom: 16px;
}

.fyf-social {
  display: flex;
  justify-content: center;
  gap: 18px;
  margin-bottom: 18px;
}

.fyf-social a {
  width: 56px;
  height: 56px;
  border-radius: 50%;
  background: #F9C7A4;
  color: #2494AE;
  text-decoration: none;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 25px;
  transition: 0.3s;
}

.fyf-social a:hover {
  transform: translateY(-4px);
  background: #ffffff;
}

.fyf-copy {
  font-size: 13px;
  opacity: 0.95;
}

@media(max-width:600px) {
  body {
    padding: 10px;
  }

  .fyf-wrapper {
    border-radius: 22px;
  }

  .fyf-banner {
    height: 190px;
  }

  .fyf-logo {
    width: 130px;
    height: 130px;
    top: -65px;
  }

  .fyf-hero {
    padding-top: 75px;
  }

  .fyf-hero h1 {
    font-size: 31px;
  }
}
</style>
</head>

<body>

<div class="fyf-wrapper">

  <div class="fyf-banner"></div>

  <section class="fyf-hero">
    <div class="fyf-logo">
      <img src="data:image/jpeg;base64," alt="FixYouFit Logo">
    </div>

    <h1>FixYouFit</h1>
    <p>Physiotherapy & Rehabilitation Clinic</p>
  </section>

  <section class="fyf-card">
    <h2><i class="fa-solid fa-circle-info"></i> About Us</h2>
    <p>
      FixYouFit is a physiotherapy and rehabilitation clinic dedicated to helping individuals recover from pain, injuries, and mobility challenges. Our personalized treatment approach focuses on faster recovery, improved movement, and long-term wellness.
    </p>
  </section>

  <section class="fyf-card fyf-location">
    <h2><i class="fa-solid fa-location-dot"></i> Koramangala Clinic</h2>
    <p>
      Expert Physiotherapy & Rehabilitation Services in Koramangala, Bangalore.
    </p>
  </section>

  <section class="fyf-card">
    <h2><i class="fa-solid fa-address-book"></i> Contact Us</h2>

    <div class="fyf-contact-row">
      <i class="fa-solid fa-phone"></i>
      <span>+91 79759 10436</span>
    </div>

    <div class="fyf-contact-row">
      <i class="fa-solid fa-envelope"></i>
      <span>vaishnavi@fixyoufit.com</span>
    </div>

    <div class="fyf-contact-row">
      <i class="fa-solid fa-globe"></i>
      <span>www.fixyoufit.com</span>
    </div>
  </section>

  <div class="fyf-buttons">
    <a href="tel:+917975910436"><i class="fa-solid fa-phone"></i> Call Now</a>
    <a href="mailto:vaishnavi@fixyoufit.com"><i class="fa-solid fa-envelope"></i> Email Us</a>
    <a href="https://fixyoufit.com/" target="_blank"><i class="fa-solid fa-globe"></i> Visit Website</a>
  </div>

  <footer class="fyf-footer">
    <h3>Connect With Us</h3>

    <div class="fyf-social">
      <a href="https://www.facebook.com/fixyoufit/" target="_blank" aria-label="Facebook">
        <i class="fa-brands fa-facebook-f"></i>
      </a>

      <a href="https://www.instagram.com/fixyoufit_physio/" target="_blank" aria-label="Instagram">
        <i class="fa-brands fa-instagram"></i>
      </a>
    </div>

    <div class="fyf-copy">
      © 2026 FixYouFit. All Rights Reserved.
    </div>
  </footer>

</div>

</body>
</html>
